{
  "name": "zoolandingpage",
  "version": "0.0.0",
  "scripts": {
    "ng": "node ./node_modules/@angular/cli/bin/ng.js",
    "start": "node ./node_modules/@angular/cli/bin/ng.js serve",
    "start:local-auth": "node ./node_modules/@angular/cli/bin/ng.js serve --host 127.0.0.1 --port 4202 --proxy-config proxy.local-auth.json",
    "start:logged": "node tools/run-with-logs.mjs --name ng-serve -- npm run start",
    "angora:build-local": "npm --prefix ../ngx-angora-css run build:ngx_angora_css_lib",
    "angora:link-local": "npm link ../ngx-angora-css/dist/ngx-angora-css-library --no-save",
    "angora:restore-registry": "npm install ngx-angora-css@1.6.1",
    "build": "node ./node_modules/@angular/cli/bin/ng.js build",
    "watch": "node ./node_modules/@angular/cli/bin/ng.js build --watch --configuration development",
    "test": "node ./node_modules/@angular/cli/bin/ng.js test",
    "test:logged": "node tools/run-with-logs.mjs --name ng-test -- npm run test -- --watch=false --browsers=ChromeHeadless",
    "serve:ssr:zoolandingpage": "node dist/zoolandingpage/server/server.mjs",
    "serve:ssr": "npm run serve:ssr:zoolandingpage",
    "serve:ssr:logged": "node tools/run-with-logs.mjs --name ssr -- npm run serve:ssr:zoolandingpage",
    "perf:baseline": "node tools/perf-baseline.mjs",
    "config:pack": "node tools/config-draft-sync.mjs pack",
    "config:unpack": "node tools/config-draft-sync.mjs unpack",
    "config:pull": "node tools/config-draft-sync.mjs pull",
    "config:push": "node tools/config-draft-sync.mjs push",
    "config:create": "node tools/config-draft-sync.mjs create",
    "config:publish": "node tools/config-draft-sync.mjs publish",
    "drafts:upload-status": "node tools/draft-upload-status.mjs --all=true --stage=published",
    "drafts:repo-preflight": "node tools/draft-repo-preflight.mjs --pull=true",
    "drafts:repo-bootstrap": "node tools/draft-repo-bootstrap.mjs",
    "drafts:public-safety-audit": "node tools/draft-public-safety-audit.mjs",
    "drafts:aws-oidc-setup": "node tools/draft-aws-oidc-setup.mjs",
    "drafts:github-setup": "node tools/draft-github-setup.mjs",
    "drafts:smoke": "node tools/draft-smoke-check.mjs",
    "angora:generate-css": "node tools/angora-generate-static-css.mjs",
    "ops:public-health": "node tools/ops/public-site-health-check.mjs",
    "ops:sync-managed-aliases": "node tools/ops/sync-managed-alias-front-door.mjs",
    "ops:sync-auth-admin-front-door": "node tools/ops/sync-auth-admin-front-door.mjs",
    "ops:probe-runtime-front-door": "node tools/ops/probe-runtime-front-door.mjs",
    "ops:configure-runtime-cache": "node tools/ops/configure-runtime-front-door-cache.mjs",
    "ops:configure-runtime-observability": "node tools/ops/configure-runtime-observability.mjs",
    "ssr:smoke": "npm run build && node --test tools/tests/ssr-server.spec.mjs",
    "test:zoneless-runner": "node --test tools/tests/zoneless-karma-runner.spec.mjs",
    "test:draft-smoke": "node --test tools/tests/draft-smoke-check.spec.mjs",
    "test:draft-upload-status": "node --test tools/tests/draft-upload-status.spec.mjs",
    "test:draft-repo-preflight": "node --test tools/tests/draft-repo-preflight.spec.mjs",
    "test:draft-public-safety-audit": "node --test tools/tests/draft-public-safety-audit.spec.mjs",
    "test:draft-aws-oidc-setup": "node --test tools/tests/draft-aws-oidc-setup.spec.mjs",
    "test:draft-github-setup": "node --test tools/tests/draft-github-setup.spec.mjs",
    "test:ops-front-door": "node --test tools/tests/ops-managed-alias-front-door.spec.mjs tools/tests/ops-auth-admin-front-door.spec.mjs tools/tests/ops-runtime-front-door-probe.spec.mjs tools/tests/ops-runtime-front-door-cache.spec.mjs tools/tests/ops-runtime-observability.spec.mjs tools/tests/ops-public-site-health-check.spec.mjs",
    "test:draft-context": "npm run build && node --test tools/tests/draft-local-context.spec.mjs",
    "ci:budgets": "node ./node_modules/@angular/cli/bin/ng.js build --configuration production",
    "ci:perf": "node tools/perf-baseline.mjs"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "ngx-angora-css": "^1.6.1",
    "rxjs": "~7.8.0",
    "simple-icons": "^16.14.0",
    "tslib": "^2.8.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/jasmine": "^5.1.9",
    "@types/node": "^20.17.19",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^5.10.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lighthouse": "^13.1.0",
    "playwright-core": "^1.59.1",
    "typescript": "~6.0.3"
  }
}
