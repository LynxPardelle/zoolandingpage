{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StructuredDataPayload",
  "type": "object",
  "required": ["version", "pageId", "domain", "entries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "pageId": { "type": "string" },
    "domain": { "type": "string" },
    "entries": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
