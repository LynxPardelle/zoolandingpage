{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServerIntegrations",
  "type": "object",
  "required": ["version", "sources", "actions"],
  "definitions": {
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "httpsAbsoluteUrl": {
      "type": "string",
      "pattern": "^https://(?![^/?#]*@)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F])[^\\\\\\s\\u0000-\\u001F\\u007F]+$"
    },
    "secretRef": {
      "type": "string",
      "pattern": "^(?:/[^\\\\\\s\\u0000-\\u001F\\u007F]+|[^/\\\\\\s\\u0000-\\u001F\\u007F]+/[^\\\\\\s\\u0000-\\u001F\\u007F]+|arn:aws:(?:ssm|secretsmanager):[^\\\\\\s\\u0000-\\u001F\\u007F]+)$"
    },
    "accessPolicy": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "authProfileId": { "$ref": "#/definitions/safeId" },
        "allowedGroups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "if": {
        "properties": {
          "required": { "const": true }
        }
      },
      "then": {
        "required": ["authProfileId"]
      },
      "additionalProperties": false
    },
    "upstreamAuth": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bearer", "api-key-header", "oauth2-client-credentials"]
        },
        "headerName": { "type": "string", "minLength": 1 },
        "tokenUrl": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "scopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "integrationResponse": {
      "type": "object",
      "properties": {
        "singleItem": { "type": "boolean" },
        "allowedFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "maxBytes": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "integrationSource": {
      "type": "object",
      "required": ["id", "method"],
      "properties": {
        "id": { "$ref": "#/definitions/safeId" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "url": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "urlTemplate": { "type": "string", "minLength": 1 },
        "allowedInputFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "credentialRef": { "$ref": "#/definitions/secretRef" },
        "response": { "$ref": "#/definitions/integrationResponse" },
        "auth": { "$ref": "#/definitions/upstreamAuth" },
        "access": { "$ref": "#/definitions/accessPolicy" }
      },
      "anyOf": [{ "required": ["url"] }, { "required": ["urlTemplate"] }],
      "allOf": [
        {
          "if": { "required": ["auth"] },
          "then": { "required": ["credentialRef"] }
        },
        {
          "if": { "required": ["credentialRef"] },
          "then": { "required": ["auth"] }
        }
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "version": { "const": 1 },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/definitions/integrationSource" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/definitions/integrationSource" }
    }
  },
  "additionalProperties": false
}
