{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentHubServerPolicy",
  "type": "object",
  "required": ["version", "hubs"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "hubs": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/serverHub" } }
  },
  "definitions": {
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "domainName": {
      "type": "string",
      "minLength": 4,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
    },
    "storagePolicy": {
      "type": "object",
      "required": ["tablesByCapability", "bucketsByCapability", "prefixes"],
      "additionalProperties": false,
      "properties": {
        "tablesByCapability": { "$ref": "#/definitions/tablesByCapability" },
        "bucketsByCapability": { "$ref": "#/definitions/bucketsByCapability" },
        "prefixes": { "$ref": "#/definitions/storagePrefixes" }
      }
    },
    "tablesByCapability": {
      "type": "object",
      "required": [
        "contentMetadataTableName",
        "contentModerationTableName",
        "contentMediaTableName",
        "contentInteractionsTableName"
      ],
      "additionalProperties": false,
      "properties": {
        "contentMetadataTableName": { "$ref": "#/definitions/awsResourceName" },
        "contentModerationTableName": { "$ref": "#/definitions/awsResourceName" },
        "contentMediaTableName": { "$ref": "#/definitions/awsResourceName" },
        "contentInteractionsTableName": { "$ref": "#/definitions/awsResourceName" }
      }
    },
    "bucketsByCapability": {
      "type": "object",
      "required": ["packageBucketName", "publishedBucketName", "mediaBucketName", "analyticsBucketName"],
      "additionalProperties": false,
      "properties": {
        "packageBucketName": { "$ref": "#/definitions/awsResourceName" },
        "publishedBucketName": { "$ref": "#/definitions/awsResourceName" },
        "mediaBucketName": { "$ref": "#/definitions/awsResourceName" },
        "analyticsBucketName": { "$ref": "#/definitions/awsResourceName" }
      }
    },
    "storagePrefixes": {
      "type": "object",
      "required": ["packagePrefix", "publishedPrefix", "mediaPrefix", "analyticsPrefix"],
      "additionalProperties": false,
      "properties": {
        "packagePrefix": { "$ref": "#/definitions/storagePrefix" },
        "publishedPrefix": { "$ref": "#/definitions/storagePrefix" },
        "mediaPrefix": { "$ref": "#/definitions/storagePrefix" },
        "analyticsPrefix": { "$ref": "#/definitions/storagePrefix" }
      }
    },
    "awsResourceName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "storagePrefix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*//)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F])[A-Za-z0-9._=/-]+/$"
    },
    "rolePolicy": {
      "type": "object",
      "required": ["roleId", "groups", "permissions"],
      "additionalProperties": false,
      "properties": {
        "roleId": { "$ref": "#/definitions/safeId" },
        "groups": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/safeId" } },
        "permissions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "hubConnection": {
      "type": "object",
      "required": ["draftDomain", "mode"],
      "additionalProperties": false,
      "properties": {
        "draftDomain": { "$ref": "#/definitions/domainName" },
        "mode": { "enum": ["read-published", "author", "admin"] }
      }
    },
    "sanitizerPolicy": {
      "type": "object",
      "required": ["policyId", "level", "allowedRoles"],
      "additionalProperties": false,
      "properties": {
        "policyId": { "$ref": "#/definitions/safeId" },
        "level": { "enum": ["strict", "balanced", "advanced", "trusted"] },
        "allowedRoles": { "type": "array", "items": { "$ref": "#/definitions/safeId" } }
      }
    },
    "spamProtection": {
      "type": "object",
      "required": ["provider", "moderationQueue"],
      "additionalProperties": false,
      "properties": {
        "provider": { "enum": ["rate-limit", "captcha", "external"] },
        "moderationQueue": { "type": "boolean" }
      }
    },
    "serverHub": {
      "type": "object",
      "required": [
        "hubId",
        "ownerDraftDomain",
        "tenantId",
        "authProfileId",
        "storage",
        "roles",
        "hubConnections",
        "sanitizerPolicies",
        "spamProtection"
      ],
      "additionalProperties": false,
      "properties": {
        "hubId": { "$ref": "#/definitions/safeId" },
        "ownerDraftDomain": { "$ref": "#/definitions/domainName" },
        "tenantId": { "$ref": "#/definitions/safeId" },
        "authProfileId": { "$ref": "#/definitions/safeId" },
        "storage": { "$ref": "#/definitions/storagePolicy" },
        "roles": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/rolePolicy" } },
        "hubConnections": { "type": "array", "items": { "$ref": "#/definitions/hubConnection" } },
        "sanitizerPolicies": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/sanitizerPolicy" } },
        "spamProtection": { "$ref": "#/definitions/spamProtection" }
      }
    }
  }
}
