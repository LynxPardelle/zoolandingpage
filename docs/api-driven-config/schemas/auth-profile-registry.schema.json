{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthProfileRegistry",
  "type": "object",
  "required": ["version", "profiles"],
  "definitions": {
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "sameOriginPath": {
      "type": "string",
      "pattern": "^/(?!/)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F]).*$"
    },
    "httpsAbsoluteUrl": {
      "type": "string",
      "pattern": "^https://(?![^/?#]*@)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F])[^\\\\\\s\\u0000-\\u001F\\u007F]+$"
    },
    "secretRef": {
      "type": "string",
      "pattern": "^(?:/[^\\\\\\s\\u0000-\\u001F\\u007F]+|[^/\\\\\\s\\u0000-\\u001F\\u007F]+/[^\\\\\\s\\u0000-\\u001F\\u007F]+|arn:aws:(?:ssm|secretsmanager):[^\\\\\\s\\u0000-\\u001F\\u007F]+)$"
    },
    "environmentClaim": {
      "type": "string",
      "pattern": "^custom:[A-Za-z0-9_]{1,20}$"
    },
    "customSigninPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "customSignupPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "setTenantClaim": { "type": "boolean" },
        "setEnvironmentClaim": { "type": "boolean" },
        "defaultGroups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "customPasswordRecoveryPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "customAuth": {
      "type": "object",
      "properties": {
        "signin": { "$ref": "#/definitions/customSigninPolicy" },
        "signup": { "$ref": "#/definitions/customSignupPolicy" },
        "passwordRecovery": { "$ref": "#/definitions/customPasswordRecoveryPolicy" }
      },
      "additionalProperties": false
    },
    "authSessionRuntime": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["server-cookie"] },
        "signinPath": { "$ref": "#/definitions/sameOriginPath" },
        "mePath": { "$ref": "#/definitions/sameOriginPath" },
        "logoutPath": { "$ref": "#/definitions/sameOriginPath" },
        "csrfCookieName": { "type": "string", "minLength": 1 },
        "csrfHeaderName": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "authAdminRuntime": {
      "type": "object",
      "properties": {
        "usersPath": { "$ref": "#/definitions/sameOriginPath" },
        "approveUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "groupsPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "suspendUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "reactivateUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" }
      },
      "additionalProperties": false
    },
    "authProfile": {
      "type": "object",
      "required": [
        "authProfileId",
        "tenantId",
        "status",
        "issuer",
        "hostedUiDomain",
        "clientId",
        "audiences",
        "callbackUrls",
        "logoutUrls",
        "loginPath",
        "logoutPath"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "pattern": "^(?!-)(?:[a-z0-9-]{1,63}\\.)+[a-z]{2,63}$"
        },
        "authProfileId": { "$ref": "#/definitions/safeId" },
        "tenantId": { "$ref": "#/definitions/safeId" },
        "status": {
          "type": "string",
          "enum": ["planned", "provisioning", "active", "suspended", "failed"]
        },
        "provider": {
          "type": "string",
          "enum": ["cognito"]
        },
        "issuer": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "hostedUiDomain": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "clientId": { "type": "string", "minLength": 1 },
        "audiences": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "callbackUrls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/httpsAbsoluteUrl" }
        },
        "logoutUrls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/httpsAbsoluteUrl" }
        },
        "loginPath": { "$ref": "#/definitions/sameOriginPath" },
        "logoutPath": { "$ref": "#/definitions/sameOriginPath" },
        "tenantClaim": { "type": "string", "minLength": 1 },
        "environmentClaim": { "$ref": "#/definitions/environmentClaim" },
        "groupClaim": { "type": "string", "minLength": 1 },
        "allowedGroups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedTokenUses": {
          "type": "array",
          "items": { "type": "string", "enum": ["id", "access"] },
          "uniqueItems": true
        },
        "adminGroups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "manageableGroups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultUserStatus": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "suspended"]
        },
        "adminGroupsAutoApproved": { "type": "boolean" },
        "maxSessionSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "socialIdpSecretRefs": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "$ref": "#/definitions/secretRef" },
              {
                "type": "object",
                "additionalProperties": { "$ref": "#/definitions/secretRef" }
              }
            ]
          }
        },
        "customAuth": { "$ref": "#/definitions/customAuth" },
        "session": { "$ref": "#/definitions/authSessionRuntime" },
        "admin": { "$ref": "#/definitions/authAdminRuntime" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "version": { "const": 1 },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/definitions/authProfile" }
    }
  },
  "additionalProperties": false
}
