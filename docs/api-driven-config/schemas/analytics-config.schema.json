{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalyticsConfigPayload",
  "type": "object",
  "required": ["version", "pageId", "domain", "sectionIds", "scrollMilestones"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "pageId": { "type": "string" },
    "domain": { "type": "string" },
    "sectionIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scrollMilestones": {
      "type": "array",
      "items": { "type": "number" }
    },
    "consentMode": { "type": "string" },
    "events": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "categories": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "quickStatsCtaEvents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "track": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ip",
          "userAgent",
          "language",
          "platform",
          "vendor",
          "cookiesEnabled",
          "doNotTrack",
          "screenWidth",
          "screenHeight",
          "colorDepth",
          "timezone",
          "geolocationLatitude",
          "geolocationLongitude",
          "geolocationAccuracy",
          "cookies",
          "battery",
          "connection"
        ]
      }
    }
  },
  "additionalProperties": false
}
