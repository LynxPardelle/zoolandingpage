{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiteConfigPayload",
  "type": "object",
  "definitions": {
    "siteRouteEntry": {
      "type": "object",
      "required": ["path", "pageId"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "pageId": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "labelKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "appRuntime": {
      "type": "object",
      "properties": {
        "identifier": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "localStorageRuntime": {
      "type": "object",
      "properties": {
        "theme": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "userPreferences": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "sessionId": { "type": "string", "minLength": 1 },
        "allowAnalytics": { "type": "string", "minLength": 1 },
        "analyticsConsentSnooze": { "type": "string", "minLength": 1 },
        "pageViewCount": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "featureRuntime": {
      "type": "object",
      "properties": {
        "debugMode": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStatsEvent": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "by": { "type": "number" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStatsPageView": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "event": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "by": { "type": "number" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStats": {
      "type": "object",
      "properties": {
        "pageView": { "$ref": "#/definitions/analyticsQuickStatsPageView" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/analyticsQuickStatsEvent" }
        }
      },
      "additionalProperties": false
    },
    "analyticsRuntime": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "consentUI": {
          "type": "string",
          "enum": ["modal", "toast", "sheet", "none"]
        },
        "consentSnoozeSeconds": { "type": "number" },
        "events": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "quickStats": { "$ref": "#/definitions/analyticsQuickStats" },
        "track": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ip",
              "userAgent",
              "language",
              "platform",
              "vendor",
              "cookiesEnabled",
              "doNotTrack",
              "screenWidth",
              "screenHeight",
              "colorDepth",
              "timezone",
              "geolocationLatitude",
              "geolocationLongitude",
              "geolocationAccuracy",
              "cookies",
              "battery",
              "connection"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "app": { "$ref": "#/definitions/appRuntime" },
        "localStorage": { "$ref": "#/definitions/localStorageRuntime" },
        "features": { "$ref": "#/definitions/featureRuntime" },
        "analytics": { "$ref": "#/definitions/analyticsRuntime" }
      },
      "additionalProperties": false
    }
  },
  "required": ["version", "domain", "routes"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "defaultPageId": { "type": "string" },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/definitions/siteRouteEntry" }
    },
    "runtime": { "$ref": "#/definitions/runtimeConfig" }
  },
  "additionalProperties": false
}
