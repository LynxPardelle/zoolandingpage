{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiteConfigPayload",
  "type": "object",
  "definitions": {
    "siteRouteEntry": {
      "type": "object",
      "required": ["path", "pageId"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "pageId": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "labelKey": { "type": "string" },
        "auth": { "$ref": "#/definitions/siteRouteAuth" }
      },
      "additionalProperties": false
    },
    "sameOriginPath": {
      "type": "string",
      "pattern": "^/(?!/)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F]).*$"
    },
    "httpsAbsoluteUrl": {
      "type": "string",
      "pattern": "^https://(?![^/?#]*@)(?!.*[\\\\\\s\\u0000-\\u001F\\u007F])[^\\\\\\s\\u0000-\\u001F\\u007F]+$"
    },
    "siteRouteAuth": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "allowedGroups": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redirectTo": { "$ref": "#/definitions/sameOriginPath" }
      },
      "additionalProperties": false
    },
    "localStorageRuntime": {
      "type": "object",
      "properties": {
        "theme": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "userPreferences": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "sessionId": { "type": "string", "minLength": 1 },
        "allowAnalytics": { "type": "string", "minLength": 1 },
        "analyticsConsentSnooze": { "type": "string", "minLength": 1 },
        "adAttribution": { "type": "string", "minLength": 1 },
        "pageViewCount": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "environmentGate": {
      "type": "object",
      "properties": {
        "local": { "type": "boolean" },
        "test": { "type": "boolean" },
        "production": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "siteEnvironmentConfig": {
      "type": "object",
      "properties": {
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "featureRuntime": {
      "type": "object",
      "properties": {
        "debugMode": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStatsEvent": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "by": { "type": "number" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStatsPageView": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "event": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "by": { "type": "number" }
      },
      "additionalProperties": false
    },
    "analyticsQuickStats": {
      "type": "object",
      "properties": {
        "pageView": { "$ref": "#/definitions/analyticsQuickStatsPageView" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/analyticsQuickStatsEvent" }
        }
      },
      "additionalProperties": false
    },
    "googleTagConversion": {
      "type": "object",
      "properties": {
        "sendTo": { "type": "string", "pattern": "^AW-[A-Z0-9_-]+/[A-Za-z0-9_-]+$" },
        "adsId": { "type": "string", "pattern": "^AW-[A-Z0-9_-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "currency": { "type": "string", "minLength": 1 }
      },
      "anyOf": [{ "required": ["sendTo"] }, { "required": ["adsId", "label"] }],
      "additionalProperties": false
    },
    "googleTagConversionValue": {
      "anyOf": [
        { "type": "string", "pattern": "^AW-[A-Z0-9_-]+/[A-Za-z0-9_-]+$" },
        { "$ref": "#/definitions/googleTagConversion" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/googleTagConversion" }
        }
      ]
    },
    "googleTagEventMapping": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "params": {
              "type": "object",
              "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$" },
              "additionalProperties": {
                "anyOf": [
                  { "type": "string", "minLength": 1, "maxLength": 200 },
                  { "type": "number" },
                  { "type": "boolean" }
                ]
              }
            },
            "conversions": {
              "type": "array",
              "items": { "$ref": "#/definitions/googleTagConversion" }
            }
          },
          "anyOf": [{ "required": ["name"] }, { "required": ["params"] }, { "required": ["conversions"] }],
          "additionalProperties": false
        }
      ]
    },
    "googleTagAttribution": {
      "type": "object",
      "properties": {
        "storage": { "type": "string", "enum": ["session", "local"] },
        "ttlDays": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "googleTagConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "environments": { "$ref": "#/definitions/environmentGate" },
        "measurementIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(G|GT)-[A-Z0-9_-]+$" }
        },
        "ga4Ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(G|GT)-[A-Z0-9_-]+$" }
        },
        "adsIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^AW-[A-Z0-9_-]+$" }
        },
        "gtmId": { "type": "string", "pattern": "^GTM-[A-Z0-9_-]+$" },
        "sendPageView": { "type": "boolean" },
        "attribution": { "$ref": "#/definitions/googleTagAttribution" },
        "events": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/googleTagEventMapping" }
        },
        "conversions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/googleTagConversionValue" }
        }
      },
      "additionalProperties": false
    },
    "analyticsRuntime": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "consentUI": {
          "type": "string",
          "enum": ["modal", "toast", "sheet", "none"]
        },
        "consentSnoozeSeconds": { "type": "number" },
        "events": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "quickStats": { "$ref": "#/definitions/analyticsQuickStats" },
        "googleTag": { "$ref": "#/definitions/googleTagConfig" },
        "track": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ip",
              "userAgent",
              "language",
              "platform",
              "vendor",
              "cookiesEnabled",
              "doNotTrack",
              "screenWidth",
              "screenHeight",
              "colorDepth",
              "timezone",
              "geolocationLatitude",
              "geolocationLongitude",
              "geolocationAccuracy",
              "cookies",
              "battery",
              "connection"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "runtimeDataSourceFieldMapping": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["path"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "fallback": {},
            "prefix": { "type": "string" },
            "suffix": { "type": "string" },
            "transform": {
              "type": "string",
              "enum": ["uriComponent", "lastPathSegment", "lastPathSegmentNumber", "titleCase"]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "runtimeDataSourceMapper": {
      "type": "object",
        "properties": {
          "itemsPath": { "type": ["string", "null"] },
          "singleItem": { "type": "boolean" },
          "prependItems": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "fields": {
            "type": ["object", "null"],
            "additionalProperties": { "$ref": "#/definitions/runtimeDataSourceFieldMapping" }
          },
          "metaFields": {
            "type": ["object", "null"],
            "additionalProperties": { "$ref": "#/definitions/runtimeDataSourceFieldMapping" }
          }
      },
      "additionalProperties": false
    },
    "runtimeDataSourceRefresh": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["load", "interval"] },
        "intervalMs": { "type": "number" }
      },
      "additionalProperties": false
    },
    "runtimeDataSource": {
      "type": "object",
      "required": ["id", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["api-proxy", "auth-admin", "content-hub"] },
        "proxySourceId": { "type": "string" },
        "authAdminSource": { "type": "string", "enum": ["account", "adminUsers"] },
        "contentHub": { "$ref": "#/definitions/contentHubRuntimeReadBinding" },
        "target": { "type": "string", "minLength": 1 },
        "statusTarget": { "type": "string" },
        "mergeMode": { "type": "string", "enum": ["replace", "appendItems"] },
        "clearTargetOnLoad": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "ssr": { "type": "boolean" },
        "pageIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredInputKeys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "skipWhenQueryParams": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "input": {
          "$ref": "#/definitions/safeRuntimeInputObject"
        },
        "mapper": {
          "anyOf": [{ "$ref": "#/definitions/runtimeDataSourceMapper" }, { "type": "null" }]
        },
        "refresh": {
          "anyOf": [{ "$ref": "#/definitions/runtimeDataSourceRefresh" }, { "type": "null" }]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "content-hub" } } },
          "then": {
            "properties": {
              "proxySourceId": { "$ref": "#/definitions/contentHubSafeId" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "sitemapConfig": {
      "type": "object",
      "properties": {
        "urls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "excludePaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "runtimeApiAction": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["api-proxy", "auth-admin", "content-hub"] },
        "proxyActionId": { "type": "string" },
        "authAdminAction": {
          "type": "string",
          "enum": ["approveUser", "setUserGroups", "suspendUser", "reactivateUser", "resetUserMfa"]
        },
        "contentHub": { "$ref": "#/definitions/contentHubRuntimeActionBinding" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "statusTarget": { "type": "string" },
        "enabled": { "type": "boolean" },
        "inputFields": {
          "type": "array",
          "items": { "$ref": "#/definitions/safeRuntimeInputFieldName" }
        },
        "requiresUserGesture": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "content-hub" } } },
          "then": {
            "properties": {
              "proxyActionId": { "$ref": "#/definitions/contentHubSafeId" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "localStorage": { "$ref": "#/definitions/localStorageRuntime" },
        "features": { "$ref": "#/definitions/featureRuntime" },
        "analytics": { "$ref": "#/definitions/analyticsRuntime" },
        "auth": { "$ref": "#/definitions/authRuntime" },
        "authRemote": { "$ref": "#/definitions/authRemoteRuntime" },
        "contentHubs": {
          "type": "array",
          "items": { "$ref": "#/definitions/contentHubRuntime" }
        },
        "dataSources": {
          "type": "array",
          "items": { "$ref": "#/definitions/runtimeDataSource" }
        },
        "apiActions": {
          "type": "array",
          "items": { "$ref": "#/definitions/runtimeApiAction" }
        }
      },
      "not": { "required": ["auth", "authRemote"] },
      "additionalProperties": false
    },
    "contentHubRuntime": {
      "type": "object",
      "required": [
        "hubId",
        "ownerDraftDomain",
        "source",
        "routeBasePath",
        "listPath",
        "articlePathPattern",
        "defaultLocale",
        "locales",
        "canonicalMode"
      ],
      "properties": {
        "hubId": { "$ref": "#/definitions/contentHubSafeId" },
        "ownerDraftDomain": { "$ref": "#/definitions/contentHubDomainName" },
        "source": { "type": "string", "enum": ["primary", "authorized"] },
        "routeBasePath": { "$ref": "#/definitions/sameOriginPath" },
        "listPath": { "$ref": "#/definitions/sameOriginPath" },
        "articlePathPattern": { "$ref": "#/definitions/sameOriginPath" },
        "defaultLocale": { "$ref": "#/definitions/contentHubLocale" },
        "locales": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/contentHubLocale" }
        },
        "canonicalMode": {
          "type": "string",
          "enum": ["owner-canonical", "host-adaptive", "noindex-shared"]
        },
        "runtimeSourceId": { "$ref": "#/definitions/contentHubSafeId" },
        "publicApiBasePath": { "$ref": "#/definitions/sameOriginPath" },
        "analyticsContext": { "$ref": "#/definitions/contentHubAnalyticsContext" },
        "publicArticles": {
          "type": "array",
          "items": { "$ref": "#/definitions/contentHubPublicArticle" }
        },
        "publicTaxonomy": {
          "type": "array",
          "items": { "$ref": "#/definitions/contentHubPublicTaxonomy" }
        }
      },
      "additionalProperties": false
    },
    "contentHubPublicArticle": {
      "type": "object",
      "required": ["articleId", "locale", "status", "title", "path", "publishedAt"],
      "properties": {
        "articleId": { "$ref": "#/definitions/contentHubSafeId" },
        "locale": { "$ref": "#/definitions/contentHubLocale" },
        "status": { "type": "string", "const": "published" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "path": { "$ref": "#/definitions/sameOriginPath" },
        "categorySlug": { "$ref": "#/definitions/contentHubSafeId" },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/definitions/contentHubSafeId" }
        },
        "publishedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorLabel": { "type": "string" },
        "canonicalPath": { "$ref": "#/definitions/sameOriginPath" },
        "robots": { "type": "string", "enum": ["index,follow", "noindex,follow", "noindex,nofollow"] }
      },
      "additionalProperties": false
    },
    "contentHubPublicTaxonomy": {
      "type": "object",
      "required": ["taxonomyId", "kind", "slug", "label", "locale"],
      "properties": {
        "taxonomyId": { "$ref": "#/definitions/contentHubSafeId" },
        "kind": { "type": "string", "enum": ["category", "tag"] },
        "slug": { "$ref": "#/definitions/contentHubSafeId" },
        "label": { "type": "string", "minLength": 1 },
        "locale": { "$ref": "#/definitions/contentHubLocale" },
        "visible": { "type": "boolean" },
        "path": { "$ref": "#/definitions/sameOriginPath" }
      },
      "additionalProperties": false
    },
    "contentHubRuntimeReadBinding": {
      "type": "object",
      "required": ["read", "hubId"],
      "properties": {
        "read": {
          "type": "string",
          "enum": ["articleList", "taxonomyList", "moderationQueue", "assetList", "revisionList", "publicBundlePreview"]
        },
        "hubId": { "$ref": "#/definitions/contentHubSafeId" },
        "articleId": { "$ref": "#/definitions/contentHubSafeId" },
        "language": { "$ref": "#/definitions/contentHubLocale" },
        "revisionId": { "$ref": "#/definitions/contentHubSafeId" },
        "taxonomyId": { "$ref": "#/definitions/contentHubSafeId" },
        "taxonomyKind": { "type": "string", "enum": ["category", "tag"] },
        "assetId": { "$ref": "#/definitions/contentHubSafeId" },
        "commentId": { "$ref": "#/definitions/contentHubSafeId" },
        "scheduleId": { "$ref": "#/definitions/contentHubSafeId" }
      },
      "additionalProperties": false
    },
    "contentHubRuntimeActionBinding": {
      "type": "object",
      "required": ["action", "hubId"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["createArticle", "updatePackage", "upsertTaxonomy", "uploadAsset", "validate", "submitReview", "publish", "schedule", "queueComment", "moderateComment", "recordInteraction", "restoreRevision"]
        },
        "hubId": { "$ref": "#/definitions/contentHubSafeId" },
        "articleId": { "$ref": "#/definitions/contentHubSafeId" },
        "language": { "$ref": "#/definitions/contentHubLocale" },
        "revisionId": { "$ref": "#/definitions/contentHubSafeId" },
        "taxonomyId": { "$ref": "#/definitions/contentHubSafeId" },
        "taxonomyKind": { "type": "string", "enum": ["category", "tag"] },
        "assetId": { "$ref": "#/definitions/contentHubSafeId" },
        "commentId": { "$ref": "#/definitions/contentHubSafeId" },
        "scheduleId": { "$ref": "#/definitions/contentHubSafeId" }
      },
      "additionalProperties": false
    },
    "safeRuntimeInputObject": {
      "type": "object",
      "propertyNames": { "$ref": "#/definitions/safeRuntimeInputFieldName" },
      "additionalProperties": { "$ref": "#/definitions/safeRuntimeInputValue" }
    },
    "safeRuntimeInputValue": {
      "anyOf": [
        {
          "type": "string",
          "not": {
            "pattern": "(?:ssm:/|secretsmanager:/|X-Amz-Signature|X-Amz-Credential|X-Amz-Security-Token|AWSAccessKeyId=|Signature=|Expires=)"
          }
        },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/safeRuntimeInputValue" }
        },
        {
          "type": "object",
          "propertyNames": { "$ref": "#/definitions/safeRuntimeInputFieldName" },
          "additionalProperties": { "$ref": "#/definitions/safeRuntimeInputValue" }
        }
      ]
    },
    "safeRuntimeInputFieldName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*(?:[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Ss][Ii][Gg][Nn][Ee][Dd])).*$",
      "not": {
        "enum": [
          "access",
          "access_token",
          "accessToken",
          "auth",
          "authorization",
          "authorizer",
          "authorizerPolicy",
          "authorizer_policy",
          "AWSAccessKeyId",
          "bucket",
          "bucketName",
          "bucket_name",
          "client_secret",
          "clientSecret",
          "credential_ref",
          "credentialRef",
          "credentials",
          "groups",
          "groups_to_roles",
          "groupsToRoles",
          "id_token",
          "idToken",
          "jwks",
          "lambdaArn",
          "lambda_arn",
          "partitionKey",
          "partition_key",
          "policy",
          "refresh_token",
          "refreshToken",
          "secret",
          "secretArn",
          "secret_arn",
          "secret_ref",
          "secretRef",
          "server_policy",
          "serverPolicy",
          "signed_url",
          "signedUrl",
          "signed_url_policy",
          "signedUrlPolicy",
          "table",
          "tableName",
          "table_name",
          "tenant",
          "tenant_id",
          "tenantId",
          "token",
          "upstream_url",
          "upstream",
          "upstreamUrl",
          "X-Amz-Credential",
          "X-Amz-Security-Token",
          "X-Amz-Signature"
        ]
      }
    },
    "contentHubSafeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "contentHubDomainName": {
      "type": "string",
      "minLength": 4,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
    },
    "contentHubLocale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16,
      "pattern": "^[a-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "contentHubAnalyticsContext": {
      "type": "object",
      "required": ["contentGroup", "eventPrefix"],
      "properties": {
        "contentGroup": { "$ref": "#/definitions/contentHubSafeId" },
        "eventPrefix": { "$ref": "#/definitions/contentHubSafeId" },
        "piiPolicy": { "type": "string", "enum": ["no-pii", "metadata-only"] }
      },
      "additionalProperties": false
    },
    "themeColors": {
      "type": "object",
      "required": [
        "bgColor",
        "textColor",
        "titleColor",
        "linkColor",
        "accentColor",
        "secondaryBgColor",
        "secondaryTextColor",
        "secondaryTitleColor",
        "secondaryLinkColor",
        "secondaryAccentColor"
      ],
      "properties": {
        "bgColor": { "type": "string" },
        "textColor": { "type": "string" },
        "titleColor": { "type": "string" },
        "linkColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "secondaryBgColor": { "type": "string" },
        "secondaryTextColor": { "type": "string" },
        "secondaryTitleColor": { "type": "string" },
        "secondaryLinkColor": { "type": "string" },
        "secondaryAccentColor": { "type": "string" }
      },
      "additionalProperties": false
    },
    "themeUi": {
      "type": "object",
      "properties": {
        "modalAccentColor": {
          "type": "string",
          "enum": ["accentColor", "secondaryAccentColor"]
        },
        "legalModalAccentColor": {
          "type": "string",
          "enum": ["accentColor", "secondaryAccentColor"]
        },
        "demoModalAccentColor": {
          "type": "string",
          "enum": ["accentColor", "secondaryAccentColor"]
        }
      },
      "additionalProperties": false
    },
    "themeConfig": {
      "type": "object",
      "required": ["palettes"],
      "properties": {
        "defaultMode": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        },
        "palettes": {
          "type": "object",
          "required": ["light", "dark"],
          "properties": {
            "light": { "$ref": "#/definitions/themeColors" },
            "dark": { "$ref": "#/definitions/themeColors" }
          },
          "additionalProperties": false
        },
        "ui": { "$ref": "#/definitions/themeUi" }
      },
      "additionalProperties": false
    },
    "draftLanguageDefinition": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "dir": {
          "type": "string",
          "enum": ["ltr", "rtl", "auto"]
        },
        "ogLocale": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "draftI18nConfig": {
      "type": "object",
      "properties": {
        "defaultLanguage": { "type": "string" },
        "supportedLanguages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [{ "type": "string", "minLength": 1 }, { "$ref": "#/definitions/draftLanguageDefinition" }]
          }
        }
      },
      "additionalProperties": false
    },
    "appIdentityConfig": {
      "type": "object",
      "properties": {
        "identifier": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      },
      "anyOf": [{ "required": ["identifier"] }, { "required": ["name"] }],
      "additionalProperties": false
    },
    "siteSeoConfig": {
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "canonicalOrigin": { "type": "string" },
        "enforceCanonicalHost": { "type": "boolean" },
        "forceHttps": { "type": "boolean" },
        "defaultImage": { "type": "string" },
        "openGraph": {
          "type": "object",
          "additionalProperties": true
        },
        "twitter": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "authSessionRuntime": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["server-cookie"] },
        "signinPath": { "$ref": "#/definitions/sameOriginPath" },
        "mePath": { "$ref": "#/definitions/sameOriginPath" },
        "logoutPath": { "$ref": "#/definitions/sameOriginPath" },
        "challengeRespondPath": { "$ref": "#/definitions/sameOriginPath" },
        "mfaSetupPath": { "$ref": "#/definitions/sameOriginPath" },
        "mfaVerifyPath": { "$ref": "#/definitions/sameOriginPath" },
        "mfaEnrollStartPath": { "$ref": "#/definitions/sameOriginPath" },
        "mfaEnrollVerifyPath": { "$ref": "#/definitions/sameOriginPath" },
        "mfaDisablePath": { "$ref": "#/definitions/sameOriginPath" },
        "csrfCookieName": { "type": "string", "minLength": 1 },
        "challengeCsrfCookieName": { "type": "string", "minLength": 1 },
        "mfaEnrollCsrfCookieName": { "type": "string", "minLength": 1 },
        "csrfHeaderName": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "authAdminRuntime": {
      "type": "object",
      "properties": {
        "usersPath": { "$ref": "#/definitions/sameOriginPath" },
        "approveUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "groupsPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "suspendUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "reactivateUserPathTemplate": { "$ref": "#/definitions/sameOriginPath" },
        "resetUserMfaPathTemplate": { "$ref": "#/definitions/sameOriginPath" }
      },
      "additionalProperties": false
    },
    "authRuntime": {
      "type": "object",
      "required": [
        "authProfileId",
        "provider",
        "issuer",
        "clientId",
        "hostedUiDomain",
        "scopes",
        "redirectPath",
        "logoutPath"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "authProfileId": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "enum": ["cognito"] },
        "issuer": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "userPoolId": { "type": "string" },
        "clientId": { "type": "string", "minLength": 1 },
        "hostedUiDomain": { "$ref": "#/definitions/httpsAbsoluteUrl" },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "redirectPath": { "$ref": "#/definitions/sameOriginPath" },
        "logoutPath": { "$ref": "#/definitions/sameOriginPath" },
        "loginPath": { "$ref": "#/definitions/sameOriginPath" },
        "loginPageId": { "type": "string" },
        "logoutPageId": { "type": "string" },
        "callbackPageId": { "type": "string" },
        "accountPageId": { "type": "string" },
        "postLoginPath": { "$ref": "#/definitions/sameOriginPath" },
        "postLogoutPath": { "$ref": "#/definitions/sameOriginPath" },
        "groupsClaim": { "type": "string" },
        "allowedGroups": {
          "type": "array",
          "items": { "type": "string" }
        },
        "session": { "$ref": "#/definitions/authSessionRuntime" },
        "admin": { "$ref": "#/definitions/authAdminRuntime" }
      },
      "additionalProperties": false
    },
    "authRemoteRuntime": {
      "type": "object",
      "required": ["authProfileId", "endpoint"],
      "properties": {
        "enabled": { "type": "boolean" },
        "authProfileId": { "type": "string", "minLength": 1 },
        "endpoint": {
          "type": "string",
          "anyOf": [
            { "$ref": "#/definitions/sameOriginPath" },
            { "$ref": "#/definitions/httpsAbsoluteUrl" }
          ]
        }
      },
      "additionalProperties": false
    },
    "siteIconConfig": {
      "type": "object",
      "properties": {
        "favicon": {
          "type": "string",
          "anyOf": [{ "pattern": "^/" }, { "pattern": "^https://" }]
        },
        "appleTouchIcon": {
          "type": "string",
          "anyOf": [{ "pattern": "^/" }, { "pattern": "^https://" }]
        },
        "maskIcon": {
          "type": "string",
          "anyOf": [{ "pattern": "^/" }, { "pattern": "^https://" }]
        },
        "maskIconColor": { "type": "string", "minLength": 1 },
        "themeColor": { "type": "string", "minLength": 1 },
        "manifest": {
          "type": "string",
          "anyOf": [{ "pattern": "^/" }, { "pattern": "^https://" }]
        }
      },
      "anyOf": [
        { "required": ["favicon"] },
        { "required": ["appleTouchIcon"] },
        { "required": ["maskIcon"] },
        { "required": ["maskIconColor"] },
        { "required": ["themeColor"] },
        { "required": ["manifest"] }
      ],
      "additionalProperties": false
    },
    "searchConsoleHtmlFile": {
      "type": "object",
      "required": ["path", "content"],
      "properties": {
        "path": { "type": "string", "pattern": "^/google[^/]*\\.html$" },
        "content": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "searchConsoleConfig": {
      "type": "object",
      "properties": {
        "googleSiteVerification": { "type": "string", "minLength": 1 },
        "htmlFile": { "$ref": "#/definitions/searchConsoleHtmlFile" },
        "environments": { "$ref": "#/definitions/environmentGate" }
      },
      "anyOf": [{ "required": ["googleSiteVerification"] }, { "required": ["htmlFile"] }],
      "additionalProperties": false
    },
    "hostOverrideConfig": {
      "type": "object",
      "properties": {
        "seo": { "$ref": "#/definitions/siteSeoConfig" },
        "searchConsole": { "$ref": "#/definitions/searchConsoleConfig" },
        "googleTag": { "$ref": "#/definitions/googleTagConfig" }
      },
      "anyOf": [{ "required": ["seo"] }, { "required": ["searchConsole"] }, { "required": ["googleTag"] }],
      "additionalProperties": false
    },
    "draftContactConfig": {
      "type": "object",
      "required": ["whatsappPhone"],
      "properties": {
        "whatsappPhone": { "type": "string", "minLength": 1 },
        "whatsappMessageKey": { "type": "string" },
        "faqMessageKey": { "type": "string" },
        "finalCtaMessageKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "brandConfig": {
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "tagline": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "additionalProperties": false
    },
    "heroAssetsConfig": {
      "type": "object",
      "properties": {
        "heroImageUrl": { "type": "string" },
        "heroImageAlt": { "type": "string" },
        "heroBackdropUrl": { "type": "string" }
      },
      "additionalProperties": false
    },
    "localizedTextMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "draftSocialLink": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "href": { "type": "string" },
        "icon": { "type": "string" },
        "label": {
          "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/localizedTextMap" }]
        },
        "labelKey": { "type": "string" },
        "ariaLabel": {
          "anyOf": [{ "type": "string" }, { "$ref": "#/definitions/localizedTextMap" }]
        },
        "ariaLabelKey": { "type": "string" },
        "target": { "type": "string" },
        "rel": { "type": "string" }
      },
      "anyOf": [{ "required": ["url"] }, { "required": ["href"] }],
      "additionalProperties": false
    },
    "statsCounterVariableConfig": {
      "type": "object",
      "properties": {
        "target": { "type": "number" },
        "durationMs": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "formatMode": { "type": "string" },
        "formatPrefix": { "type": "string" },
        "formatSuffix": { "type": "string" }
      },
      "additionalProperties": false
    },
    "draftUiConfig": {
      "type": "object",
      "properties": {
        "mobileMenuAriaLabel": { "type": "string" },
        "brandTextFallback": { "type": "string" },
        "contact": { "$ref": "#/definitions/draftContactConfig" }
      },
      "additionalProperties": true
    },
    "siteSharedConfig": {
      "type": "object",
      "required": ["appIdentity", "theme", "i18n"],
      "properties": {
        "appIdentity": { "$ref": "#/definitions/appIdentityConfig" },
        "theme": { "$ref": "#/definitions/themeConfig" },
        "i18n": { "$ref": "#/definitions/draftI18nConfig" },
        "icons": { "$ref": "#/definitions/siteIconConfig" },
        "seo": { "$ref": "#/definitions/siteSeoConfig" },
        "searchConsole": { "$ref": "#/definitions/searchConsoleConfig" },
        "hostOverrides": {
          "type": "object",
          "patternProperties": {
            "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)*[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$": {
              "$ref": "#/definitions/hostOverrideConfig"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "siteDefaultsConfig": {
      "type": "object",
      "properties": {
        "brand": { "$ref": "#/definitions/brandConfig" },
        "heroAssets": { "$ref": "#/definitions/heroAssetsConfig" },
        "ctaTargets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "navigation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "socialLinks": {
          "type": "array",
          "items": { "$ref": "#/definitions/draftSocialLink" }
        },
        "statsCounters": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/statsCounterVariableConfig" }
        },
        "ui": { "$ref": "#/definitions/draftUiConfig" }
      },
      "additionalProperties": true
    }
  },
  "required": ["version", "domain", "routes", "site"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "environments": {
      "type": "object",
      "properties": {
        "local": { "$ref": "#/definitions/siteEnvironmentConfig" },
        "test": { "$ref": "#/definitions/siteEnvironmentConfig" },
        "production": { "$ref": "#/definitions/siteEnvironmentConfig" }
      },
      "additionalProperties": false
    },
    "defaultPageId": { "type": "string" },
    "notFoundPageId": { "type": "string" },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/definitions/siteRouteEntry" }
    },
    "site": { "$ref": "#/definitions/siteSharedConfig" },
    "defaults": { "$ref": "#/definitions/siteDefaultsConfig" },
    "sitemap": { "$ref": "#/definitions/sitemapConfig" },
    "runtime": { "$ref": "#/definitions/runtimeConfig" }
  },
  "additionalProperties": false
}
