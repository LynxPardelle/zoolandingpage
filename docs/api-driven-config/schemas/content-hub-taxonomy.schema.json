{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentHubTaxonomyRecords",
  "type": "object",
  "required": ["version", "hubId", "records"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "hubId": { "$ref": "#/definitions/safeId" },
    "records": { "type": "array", "items": { "$ref": "#/definitions/taxonomyRecord" } }
  },
  "definitions": {
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "domainName": {
      "type": "string",
      "minLength": 4,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "locale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16,
      "pattern": "^[a-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "localizedLabels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "taxonomyOverride": {
      "type": "object",
      "required": ["draftDomain", "visible"],
      "additionalProperties": false,
      "properties": {
        "draftDomain": { "$ref": "#/definitions/domainName" },
        "visible": { "type": "boolean" },
        "labels": { "$ref": "#/definitions/localizedLabels" }
      }
    },
    "visibilityPolicy": {
      "type": "object",
      "required": ["default", "overrides"],
      "additionalProperties": false,
      "properties": {
        "default": { "enum": ["visible", "hidden"] },
        "overrides": { "type": "array", "items": { "$ref": "#/definitions/taxonomyOverride" } }
      }
    },
    "taxonomyRecord": {
      "type": "object",
      "required": ["taxonomyId", "kind", "slug", "createdByDraftDomain", "defaultLocale", "labels", "visibility"],
      "additionalProperties": false,
      "properties": {
        "taxonomyId": { "$ref": "#/definitions/safeId" },
        "kind": { "enum": ["category", "tag"] },
        "slug": { "$ref": "#/definitions/slug" },
        "createdByDraftDomain": { "$ref": "#/definitions/domainName" },
        "defaultLocale": { "$ref": "#/definitions/locale" },
        "labels": { "$ref": "#/definitions/localizedLabels" },
        "visibility": { "$ref": "#/definitions/visibilityPolicy" }
      }
    }
  }
}
