{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "I18nPayload",
  "type": "object",
  "required": ["version", "pageId", "domain", "lang", "dictionary"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "pageId": { "type": "string" },
    "domain": { "type": "string" },
    "lang": { "type": "string" },
    "dictionary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
