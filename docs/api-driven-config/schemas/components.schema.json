{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentsPayload",
  "description": "Schema for API or draft JSON component payloads. Child composition in JSON should stay ID-based; inline nested component objects are a runtime TypeScript composition feature and are intentionally out of scope for this payload schema.",
  "type": "object",
  "definitions": {
    "interactionNumericSource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["source", "fieldId"],
          "properties": {
            "source": { "const": "field" },
            "fieldId": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["source", "value"],
          "properties": {
            "source": { "const": "literal" },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        }
      ]
    },
    "interactionComputationStep": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "value"],
          "properties": {
            "op": { "enum": ["add", "subtract", "multiply", "divide", "min", "max"] },
            "value": { "$ref": "#/definitions/interactionNumericSource" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "const": "clamp" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "const": "round" },
            "precision": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "enum": ["abs", "floor", "ceil"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "interactionComputedDefinition": {
      "type": "object",
      "required": ["resultId", "initial"],
      "properties": {
        "resultId": { "type": "string" },
        "initial": { "$ref": "#/definitions/interactionNumericSource" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionComputationStep" }
        }
      },
      "additionalProperties": false
    },
    "interactionValidationRule": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["required", "email"] },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "fieldId"],
          "properties": {
            "type": { "const": "matchesField" },
            "fieldId": { "type": "string", "minLength": 1 },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "enum": ["min", "max", "minLength", "maxLength"] },
            "value": { "type": "number" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "pattern" },
            "value": { "type": "string" },
            "flags": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "genericInputOption": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": { "type": ["string", "number", "boolean"] },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "disabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "genericInputOptionsSource": {
      "type": "object",
      "required": ["source", "path"],
      "properties": {
        "source": { "enum": ["i18n", "var"] },
        "path": { "type": "string" },
        "fallback": {
          "type": "array",
          "items": { "$ref": "#/definitions/genericInputOption" }
        }
      },
      "additionalProperties": false
    },
    "genericInputOptionsValue": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/definitions/genericInputOption" }
        },
        { "$ref": "#/definitions/genericInputOptionsSource" }
      ]
    },
    "genericInputConfig": {
      "type": "object",
      "required": ["fieldId", "controlType"],
      "properties": {
        "fieldId": { "type": "string" },
        "controlType": { "enum": ["text", "textarea", "number", "range", "checkbox", "switch", "select", "file", "button-group"] },
        "inputType": { "enum": ["text", "email", "password", "search", "tel", "url"] },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "helperText": { "type": "string" },
        "placeholder": { "type": "string" },
        "ariaLabel": { "type": "string" },
        "classes": { "type": "string" },
        "labelClasses": { "type": "string" },
        "descriptionClasses": { "type": "string" },
        "helperTextClasses": { "type": "string" },
        "fieldClasses": { "type": "string" },
        "inputClasses": { "type": "string" },
        "dropdownTriggerClasses": { "type": "string" },
        "dropdownIndicatorText": { "type": "string" },
        "dropdownIndicatorClasses": { "type": "string" },
        "dropdownConfig": { "type": "object" },
        "labelTextConfig": { "type": "object" },
        "descriptionTextConfig": { "type": "object" },
        "helperTextConfig": { "type": "object" },
        "errorTextConfig": { "type": "object" },
        "dropdownTriggerTextConfig": { "type": "object" },
        "optionContainerClasses": { "type": "string" },
        "optionClasses": { "type": "string" },
        "activeOptionClasses": { "type": "string" },
        "errorClasses": { "type": "string" },
        "validationChecklistClasses": { "type": "string" },
        "validationChecklistItemClasses": { "type": "string" },
        "validationChecklistValidItemClasses": { "type": "string" },
        "validationChecklistInvalidItemClasses": { "type": "string" },
        "validationChecklistIconClasses": { "type": "string" },
        "validationChecklistLabel": { "type": "string" },
        "validationChecklistValidIcon": { "type": "string" },
        "validationChecklistInvalidIcon": { "type": "string" },
        "valuePrefix": { "type": "string" },
        "valueSuffix": { "type": "string" },
        "showRangeValue": { "type": "boolean" },
        "showValidationChecklist": { "type": "boolean" },
        "showPasswordToggle": { "type": "boolean" },
        "showPasswordLabel": { "type": "string" },
        "hidePasswordLabel": { "type": "string" },
        "passwordToggleClasses": { "type": "string" },
        "passwordToggleIconClasses": { "type": "string" },
        "passwordToggleShowIcon": { "type": "string" },
        "passwordToggleHideIcon": { "type": "string" },
        "options": { "$ref": "#/definitions/genericInputOptionsValue" },
        "autocompleteOptions": { "$ref": "#/definitions/genericInputOptionsValue" },
        "autocompleteMinLength": { "type": "number" },
        "autocompleteMaxOptions": { "type": "number" },
        "autocompleteMatchMode": { "enum": ["none", "startsWith", "contains"] },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "rows": { "type": "number" },
        "required": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "readOnly": { "type": "boolean" },
        "validation": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionValidationRule" }
        }
      },
      "additionalProperties": true
    },
    "genericButtonConfig": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classes": { "type": "string" },
        "disabledClasses": { "type": "string" },
        "loadingClasses": { "type": "string" },
        "styles": { "type": "object" },
        "type": { "enum": ["button", "submit", "reset"] },
        "label": { "type": "string" },
        "loadingLabel": { "type": "string" },
        "disabled": { "type": "boolean" },
        "disabledWhenInvalidScope": { "type": "boolean" },
        "loading": { "type": "boolean" },
        "icon": { "type": "string" },
        "iconClasses": { "type": "string" },
        "iconPosition": { "enum": ["before", "after"] },
        "spinnerClasses": { "type": "string" },
        "role": { "type": "string" },
        "ariaLabel": { "type": "string" },
        "tabIndex": { "type": "number" },
        "ariaSelected": { "type": "boolean" },
        "ariaExpanded": { "type": "boolean" },
        "ariaHaspopup": { "type": "boolean" },
        "ariaControls": { "type": "string" },
        "ariaActiveDescendant": { "type": "string" },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "searchSuggestion": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "href": { "type": "string" },
        "target": { "enum": ["_self", "_blank", "_parent", "_top"] }
      },
      "additionalProperties": true
    },
    "searchBoxConfig": {
      "type": "object",
      "properties": {
        "minLength": { "type": "number" },
        "debounceMs": { "type": "number" },
        "ariaLabel": { "type": "string" },
        "placeholder": { "type": "string" },
        "classes": { "type": "string" },
        "inputClasses": { "type": "string" },
        "resultsClasses": { "type": "string" },
        "collapsed": { "type": "boolean" },
        "triggerIcon": { "type": "string" },
        "closeIcon": { "type": "string" },
        "triggerAriaLabel": { "type": "string" },
        "closeAriaLabel": { "type": "string" },
        "triggerClasses": { "type": "string" },
        "panelClasses": { "type": "string" },
        "panelContentClasses": { "type": "string" },
        "panelInputWrapperClasses": { "type": "string" },
        "historyEnabled": { "type": "boolean" },
        "historyLimit": { "type": "number" },
        "maxResults": { "type": "number" },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "#/definitions/searchSuggestion" }
        }
      },
      "additionalProperties": true
    },
    "accordionItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": ["string", "number"] },
        "titleKey": { "type": "string" },
        "content": { "type": ["string", "number"] },
        "contentKey": { "type": "string" },
        "summary": { "type": ["string", "number"] },
        "summaryKey": { "type": "string" },
        "meta": { "type": ["string", "number"] },
        "metaKey": { "type": "string" },
        "detailItems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detailItemsKey": { "type": "string" },
        "detailItemKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indexLabel": { "type": ["string", "number"] },
        "step": { "type": "number" },
        "icon": { "type": ["string", "number"] },
        "disabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "accordionConfig": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["single", "multiple"] },
        "allowToggle": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/accordionItem" }
        },
        "itemsSource": {
          "type": "object",
          "required": ["source", "path"],
          "properties": {
            "source": { "enum": ["i18n", "var"] },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        "renderMode": { "enum": ["default", "detail"] },
        "activeId": { "type": "string" },
        "activeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scrollBehavior": { "enum": ["none", "center"] },
        "detailMetaIconName": { "type": "string" },
        "detailItemIconName": { "type": "string" },
        "toggleIconName": { "type": "string" },
        "detailContentLabel": { "type": ["string", "number"] },
        "detailItemsLabel": { "type": ["string", "number"] }
      },
      "additionalProperties": true
    },
    "tabDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": ["string", "number"] },
        "labelKey": { "type": "string" },
        "title": { "type": ["string", "number"] },
        "titleKey": { "type": "string" },
        "summary": { "type": ["string", "number"] },
        "summaryKey": { "type": "string" },
        "content": { "type": ["string", "number"] },
        "contentKey": { "type": "string" },
        "meta": { "type": ["string", "number"] },
        "metaKey": { "type": "string" },
        "detailItems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detailItemsKey": { "type": "string" },
        "detailItemKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indexLabel": { "type": ["string", "number"] },
        "step": { "type": "number" },
        "icon": { "type": ["string", "number"] },
        "disabled": { "type": "boolean" },
        "lazy": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "tabGroupConfig": {
      "type": "object",
      "properties": {
        "activeId": { "type": "string" },
        "tabs": {
          "type": "array",
          "items": { "$ref": "#/definitions/tabDefinition" }
        },
        "tabsSource": {
          "type": "object",
          "required": ["source", "path"],
          "properties": {
            "source": { "enum": ["i18n", "var"] },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        "layout": { "enum": ["default", "split-detail"] },
        "orientation": { "enum": ["horizontal", "vertical"] },
        "scrollBehavior": { "enum": ["none", "center"] },
        "listHeaderLabel": { "type": ["string", "number"] },
        "detailMetaIconName": { "type": "string" },
        "detailContentLabel": { "type": ["string", "number"] },
        "detailItemsLabel": { "type": ["string", "number"] },
        "detailItemIconName": { "type": "string" }
      },
      "additionalProperties": true
    },
    "statsCounterConfig": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": { "type": "number" },
        "durationMs": { "type": "number" },
        "startOnVisible": { "type": "boolean" },
        "ariaLabel": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "formatMode": { "type": "string" },
        "formatPrefix": { "type": "string" },
        "formatSuffix": { "type": "string" }
      },
      "additionalProperties": false
    },
    "interactionScopeConfig": {
      "type": "object",
      "properties": {
        "scopeId": { "type": "string" },
        "id": { "type": "string" },
        "tag": { "enum": ["div", "section", "form"] },
        "classes": { "type": "string" },
        "role": { "type": "string" },
        "ariaLabel": { "type": "string" },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "initialValues": { "type": "object" },
        "computations": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionComputedDefinition" }
        },
        "submitEventInstructions": { "type": "string" }
      },
      "additionalProperties": true
    },
    "genericCellConfig": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": {},
        "row": {},
        "valuePath": { "type": "string" },
        "format": { "enum": ["text", "number", "date", "boolean", "json", "list"] },
        "emptyText": { "type": "string" },
        "trueText": { "type": "string" },
        "falseText": { "type": "string" },
        "itemPath": { "type": "string" },
        "separator": { "type": "string" },
        "componentId": { "type": "string" },
        "componentIds": {
          "type": "array",
