{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentsPayload",
  "description": "Schema for API or draft JSON component payloads. Child composition in JSON should stay ID-based; inline nested component objects are a runtime TypeScript composition feature and are intentionally out of scope for this payload schema.",
  "type": "object",
  "definitions": {
    "interactionNumericSource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["source", "fieldId"],
          "properties": {
            "source": { "const": "field" },
            "fieldId": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["source", "value"],
          "properties": {
            "source": { "const": "literal" },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        }
      ]
    },
    "interactionComputationStep": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "value"],
          "properties": {
            "op": { "enum": ["add", "subtract", "multiply", "divide", "min", "max"] },
            "value": { "$ref": "#/definitions/interactionNumericSource" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "const": "clamp" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "const": "round" },
            "precision": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op"],
          "properties": {
            "op": { "enum": ["abs", "floor", "ceil"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "interactionComputedDefinition": {
      "type": "object",
      "required": ["resultId", "initial"],
      "properties": {
        "resultId": { "type": "string" },
        "initial": { "$ref": "#/definitions/interactionNumericSource" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionComputationStep" }
        }
      },
      "additionalProperties": false
    },
    "interactionValidationRule": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["required", "email"] },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "enum": ["min", "max", "minLength", "maxLength"] },
            "value": { "type": "number" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "pattern" },
            "value": { "type": "string" },
            "flags": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "genericInputOption": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": { "type": ["string", "number", "boolean"] },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "disabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "genericInputConfig": {
      "type": "object",
      "required": ["fieldId", "controlType"],
      "properties": {
        "fieldId": { "type": "string" },
        "controlType": { "enum": ["text", "textarea", "number", "range", "checkbox", "select", "button-group"] },
        "inputType": { "enum": ["text", "email", "password", "search", "tel", "url"] },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "helperText": { "type": "string" },
        "placeholder": { "type": "string" },
        "ariaLabel": { "type": "string" },
        "classes": { "type": "string" },
        "labelClasses": { "type": "string" },
        "descriptionClasses": { "type": "string" },
        "helperTextClasses": { "type": "string" },
        "fieldClasses": { "type": "string" },
        "inputClasses": { "type": "string" },
        "dropdownTriggerClasses": { "type": "string" },
        "dropdownIndicatorText": { "type": "string" },
        "dropdownIndicatorClasses": { "type": "string" },
        "dropdownConfig": { "type": "object" },
        "labelTextConfig": { "type": "object" },
        "descriptionTextConfig": { "type": "object" },
        "helperTextConfig": { "type": "object" },
        "errorTextConfig": { "type": "object" },
        "dropdownTriggerTextConfig": { "type": "object" },
        "optionContainerClasses": { "type": "string" },
        "optionClasses": { "type": "string" },
        "activeOptionClasses": { "type": "string" },
        "errorClasses": { "type": "string" },
        "valuePrefix": { "type": "string" },
        "valueSuffix": { "type": "string" },
        "showRangeValue": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/genericInputOption" }
        },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "rows": { "type": "number" },
        "required": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "readOnly": { "type": "boolean" },
        "validation": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionValidationRule" }
        }
      },
      "additionalProperties": true
    },
    "searchSuggestion": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "href": { "type": "string" },
        "target": { "enum": ["_self", "_blank", "_parent", "_top"] }
      },
      "additionalProperties": true
    },
    "searchBoxConfig": {
      "type": "object",
      "properties": {
        "minLength": { "type": "number" },
        "debounceMs": { "type": "number" },
        "ariaLabel": { "type": "string" },
        "placeholder": { "type": "string" },
        "classes": { "type": "string" },
        "inputClasses": { "type": "string" },
        "resultsClasses": { "type": "string" },
        "collapsed": { "type": "boolean" },
        "triggerIcon": { "type": "string" },
        "closeIcon": { "type": "string" },
        "triggerAriaLabel": { "type": "string" },
        "closeAriaLabel": { "type": "string" },
        "triggerClasses": { "type": "string" },
        "panelClasses": { "type": "string" },
        "panelContentClasses": { "type": "string" },
        "panelInputWrapperClasses": { "type": "string" },
        "historyEnabled": { "type": "boolean" },
        "historyLimit": { "type": "number" },
        "maxResults": { "type": "number" },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "#/definitions/searchSuggestion" }
        }
      },
      "additionalProperties": true
    },
    "accordionItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": ["string", "number"] },
        "titleKey": { "type": "string" },
        "content": { "type": ["string", "number"] },
        "contentKey": { "type": "string" },
        "summary": { "type": ["string", "number"] },
        "summaryKey": { "type": "string" },
        "meta": { "type": ["string", "number"] },
        "metaKey": { "type": "string" },
        "detailItems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detailItemsKey": { "type": "string" },
        "detailItemKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indexLabel": { "type": ["string", "number"] },
        "step": { "type": "number" },
        "icon": { "type": ["string", "number"] },
        "disabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "accordionConfig": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["single", "multiple"] },
        "allowToggle": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/accordionItem" }
        },
        "itemsSource": {
          "type": "object",
          "required": ["source", "path"],
          "properties": {
            "source": { "enum": ["i18n", "var"] },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        "renderMode": { "enum": ["default", "detail"] },
        "activeId": { "type": "string" },
        "activeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scrollBehavior": { "enum": ["none", "center"] },
        "detailMetaIconName": { "type": "string" },
        "detailItemIconName": { "type": "string" },
        "toggleIconName": { "type": "string" },
        "detailContentLabel": { "type": ["string", "number"] },
        "detailItemsLabel": { "type": ["string", "number"] }
      },
      "additionalProperties": true
    },
    "tabDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": ["string", "number"] },
        "labelKey": { "type": "string" },
        "title": { "type": ["string", "number"] },
        "titleKey": { "type": "string" },
        "summary": { "type": ["string", "number"] },
        "summaryKey": { "type": "string" },
        "content": { "type": ["string", "number"] },
        "contentKey": { "type": "string" },
        "meta": { "type": ["string", "number"] },
        "metaKey": { "type": "string" },
        "detailItems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detailItemsKey": { "type": "string" },
        "detailItemKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indexLabel": { "type": ["string", "number"] },
        "step": { "type": "number" },
        "icon": { "type": ["string", "number"] },
        "disabled": { "type": "boolean" },
        "lazy": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "tabGroupConfig": {
      "type": "object",
      "properties": {
        "activeId": { "type": "string" },
        "tabs": {
          "type": "array",
          "items": { "$ref": "#/definitions/tabDefinition" }
        },
        "tabsSource": {
          "type": "object",
          "required": ["source", "path"],
          "properties": {
            "source": { "enum": ["i18n", "var"] },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        "layout": { "enum": ["default", "split-detail"] },
        "orientation": { "enum": ["horizontal", "vertical"] },
        "scrollBehavior": { "enum": ["none", "center"] },
        "listHeaderLabel": { "type": ["string", "number"] },
        "detailMetaIconName": { "type": "string" },
        "detailContentLabel": { "type": ["string", "number"] },
        "detailItemsLabel": { "type": ["string", "number"] },
        "detailItemIconName": { "type": "string" }
      },
      "additionalProperties": true
    },
    "interactionScopeConfig": {
      "type": "object",
      "properties": {
        "scopeId": { "type": "string" },
        "id": { "type": "string" },
        "tag": { "enum": ["div", "section", "form"] },
        "classes": { "type": "string" },
        "role": { "type": "string" },
        "ariaLabel": { "type": "string" },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "initialValues": { "type": "object" },
        "computations": {
          "type": "array",
          "items": { "$ref": "#/definitions/interactionComputedDefinition" }
        },
        "submitEventInstructions": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "required": ["version", "pageId", "domain", "components"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "pageId": { "type": "string" },
    "domain": { "type": "string" },
    "components": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "condition": { "type": ["string", "boolean"] },
          "valueInstructions": { "type": "string" },
          "eventInstructions": { "type": "string" },
          "loopConfig": {
            "oneOf": [
              {
                "type": "object",
                "required": ["source", "path", "templateId"],
                "properties": {
                  "source": { "enum": ["var", "i18n"] },
                  "path": { "type": "string" },
                  "templateId": { "type": "string" },
                  "idPrefix": { "type": "string" }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["source", "count", "templateId"],
                "properties": {
                  "source": { "const": "repeat" },
                  "count": { "type": "integer", "minimum": 0 },
                  "templateId": { "type": "string" },
                  "idPrefix": { "type": "string" }
                },
                "additionalProperties": false
              }
            ]
          },
          "config": {
            "type": "object",
            "description": "Type-specific JSON config. For payload authoring, config.components should remain an array of component ID strings even though the in-memory runtime can compose inline child component objects.",
            "properties": {
              "itemsSource": {
                "type": "object",
                "required": ["source", "path"],
                "properties": {
                  "source": { "enum": ["i18n", "var"] },
                  "path": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": true
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "input" }
              }
            },
            "then": {
              "properties": {
                "config": { "$ref": "#/definitions/genericInputConfig" }
              },
              "required": ["config"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "interaction-scope" }
              }
            },
            "then": {
              "properties": {
                "config": { "$ref": "#/definitions/interactionScopeConfig" }
              },
              "required": ["config"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "search-box" }
              }
            },
            "then": {
              "properties": {
                "config": { "$ref": "#/definitions/searchBoxConfig" }
              },
              "required": ["config"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "accordion" }
              }
            },
            "then": {
              "properties": {
                "config": { "$ref": "#/definitions/accordionConfig" }
              },
              "required": ["config"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "tab-group" }
              }
            },
            "then": {
              "properties": {
                "config": { "$ref": "#/definitions/tabGroupConfig" }
              },
              "required": ["config"]
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
