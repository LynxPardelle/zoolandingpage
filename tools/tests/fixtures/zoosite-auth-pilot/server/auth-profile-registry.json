{
  "version": 1,
  "profiles": [
    {
      "domain": "zoositioweb.com.mx",
      "authProfileId": "staff",
      "tenantId": "zoosite",
      "status": "planned",
      "provider": "cognito",
      "issuer": "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_ZOOSITEPLANNED",
      "hostedUiDomain": "https://zoosite-staff-planned.auth.us-east-1.amazoncognito.com",
      "clientId": "zoosite-staff-public-client-planned",
      "audiences": [
        "zoosite-staff-public-client-planned"
      ],
      "callbackUrls": [
        "https://zoositioweb.com.mx/auth/callback",
        "https://zoositioweb.com/auth/callback"
      ],
      "logoutUrls": [
        "https://zoositioweb.com.mx/acceso",
        "https://zoositioweb.com/acceso"
      ],
      "loginPath": "/acceso",
      "logoutPath": "/acceso",
      "tenantClaim": "custom:tenant_id",
      "environmentClaim": "custom:zoolanding_env",
      "environmentClaimMode": "list",
      "groupClaim": "cognito:groups",
      "allowedGroups": [
        "zoosite-client",
        "zoosite-admin"
      ],
      "allowedTokenUses": [
        "id",
        "access"
      ],
      "mfa": {
        "mode": "optional",
        "totp": {
          "enabled": true
        }
      },
      "session": {
        "mode": "server-cookie",
        "signinPath": "/auth/session/signin",
        "mePath": "/auth/session/me",
        "logoutPath": "/auth/session/logout",
        "challengeRespondPath": "/auth/session/challenge/respond",
        "mfaSetupPath": "/auth/session/mfa/setup",
        "mfaVerifyPath": "/auth/session/mfa/verify",
        "csrfCookieName": "zlp_csrf",
        "challengeCsrfCookieName": "zlp_challenge_csrf",
        "csrfHeaderName": "X-ZLP-CSRF"
      },
      "socialIdpSecretRefs": {
        "google": "/zoolanding/auth/zoosite/staff/google",
        "facebook": "/zoolanding/auth/zoosite/staff/facebook"
      }
    }
  ]
}
