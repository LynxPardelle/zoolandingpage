            "to": "config.classes",
            "sources": [
              "buttonClasses"
            ]
          },
          {
            "to": "config.ariaLabel",
            "sources": [
              "ariaLabel"
            ]
          },
          {
            "to": "meta_title",
            "sources": [
              "key"
            ]
          }
        ]
